  "percentFormated": "{percent}",
  "@percentFormated": {
    "placeholders": {
      "percent": {
        "type": "num",
        "format": "percentPattern",
        "example": "45%"
      }
    }
  },
  "confirmBasketWithXProduct": "{products, plural, =0{السلة فارغة} =1{اشترِ منتجي} other{أكد سلة المشتريات الخاصة بي مع {products} منتجات}}",
  "@confirmBasketWithXProduct": {
    "placeholders": {
      "products": {
        "type": "num"
      }
    }
  },
  "productType": "{productTypeVariable, select, electronics{إلكترونيات} clothing{ملابس} home{منزل} books{كتب} sports{رياضة} other{مجهول}}",
  "@productType": {
    "placeholders": {
      "productTypeVariable": {
        "type": "String"
      }
    }
  }
